# Point this at your own duplicated VoxCPM2 Space for reliability + tunable inference.
# The public demo is shared/rate-limited and exposes a fixed 8-argument /generate signature.
HF_VOXCPM2_URL=https://openbmb-voxcpm-demo.hf.space
HF_REQUEST_TIMEOUT=60000
HF_INFERENCE_TIMEOUT=300000
# Optional: JSON array of extra /generate arguments appended in your Space's expected order.
# Only for a self-hosted Space that exposes more controls than the public demo, e.g.:
#   VOXCPM2_EXTRA_PARAMS=[20, true]   # inference_timesteps=20 (higher=better), retry_badcase=true
# Leave unset for the public demo (its signature would reject extra arguments).
# VOXCPM2_EXTRA_PARAMS=
GEMINI_REQUEST_TIMEOUT=60000
GEMINI_API_KEY=your_google_gemini_api_key_here
